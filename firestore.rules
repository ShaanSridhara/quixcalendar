rules_version = '2';

// Quix Calendar — Firestore security rules
// -----------------------------------------------------------------------------
// Goals:
//  1. No anonymous access. Every request must come from a signed-in user.
//  2. Per-team write isolation. A user can only change a calendar / its events
//     if they OWN that calendar or hold a leadership role on it. Members can
//     RSVP to events they're invited to. Nobody can tamper with another team's
//     data by guessing document IDs.
//  3. No identity tampering. Leaders can update a teammate's role / absence /
//     membership, but NOBODY except the account owner can change a user's
//     displayName, email, or avatar (blocks impersonation).
//  4. Bug reports are write-once by users, readable only by the platform owner.
// -----------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // The account that owns the deployment (platform super-admin).
    function isPlatformAdmin() {
      return isSignedIn()
        && request.auth.uid == 'FFCcwj3440ZXFcDZVAZzXmGuRQw2';
    }

    function calendar(calId) {
      return get(/databases/$(database)/documents/calendars/$(calId)).data;
    }

    // True if the signed-in user owns, or holds any role on, the given calendar.
    function leadsCalendar(calId) {
      return calId is string
        && exists(/databases/$(database)/documents/calendars/$(calId))
        && (
          calendar(calId).uid == request.auth.uid
          || request.auth.uid in calendar(calId).get('roles', {})
        );
    }

    // ── Users ────────────────────────────────────────────────────────────────
    // Profiles are readable by any signed-in user (needed to render member
    // names & avatars). You may create/edit only your OWN profile. Leaders may
    // update a teammate's non-identity fields (role, absence count, membership,
    // per-calendar subsection) — but can never change someone's name, email, or
    // avatar.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || (
          request.resource.data.get('displayName', null) == resource.data.get('displayName', null)
          && request.resource.data.get('email', null) == resource.data.get('email', null)
          && request.resource.data.get('pfpUrl', null) == resource.data.get('pfpUrl', null)
        )
      );
      allow delete: if request.auth.uid == userId || isPlatformAdmin();
    }

    // ── Calendars (teams) ─────────────────────────────────────────────────────
    // Readable by any signed-in user (invite-code lookup needs this, and shared
    // calendars are read by members). Only the owner or a role-holder may edit;
    // only the owner (or platform admin) may delete. Creation must stamp the
    // creator as the owner.
    match /calendars/{calId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && (
          resource.data.uid == request.auth.uid
          || request.auth.uid in resource.data.get('roles', {})
          || isPlatformAdmin()
        );
      allow delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isPlatformAdmin());
    }

    // ── Events (meetings / tasks / events / outreach) ─────────────────────────
    // Create: must stamp the creator as owner.
    // Update: the event owner, anyone invited (RSVP / mark complete), or a
    //         leader of the event's calendar (attendance, outreach, edits).
    // Delete: the event owner, a leader of its calendar, or platform admin.
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && (
          resource.data.uid == request.auth.uid
          || request.auth.uid in resource.data.get('inviteeUids', [])
          || leadsCalendar(resource.data.get('calendarId', ''))
          || isPlatformAdmin()
        );
      allow delete: if isSignedIn()
        && (
          resource.data.uid == request.auth.uid
          || leadsCalendar(resource.data.get('calendarId', ''))
          || isPlatformAdmin()
        );
    }

    // ── Bug reports & feedback ────────────────────────────────────────────────
    // Any signed-in user may file one (stamped with their own uid). Only the
    // platform owner can read them; nobody can edit or delete from the client.
    match /bugReports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if isPlatformAdmin();
    }

    // ── Default deny ───────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
