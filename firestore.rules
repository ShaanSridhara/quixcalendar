rules_version = '2';

// Quix Calendar — Firestore security rules
// -----------------------------------------------------------------------------
// Baseline posture: nothing is world-readable or world-writable. Every request
// must come from a signed-in user. This is the critical guarantee for running
// multiple FTC teams on one backend — an anonymous visitor can never read or
// write any team's calendars, events, members, or bug reports.
//
// Cross-member writes (a Captain marking a teammate's absence, assigning roles,
// RSVPing to an event, etc.) are intentionally allowed between authenticated
// users, because the app's leadership tools depend on them. Doc IDs are random
// Firestore IDs, not enumerable. Field-level, per-team hardening is a sensible
// follow-up once the multi-team model stabilises.
// -----------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // Platform super-admin (the account that owns the deployment).
    function isPlatformAdmin() {
      return request.auth != null
        && request.auth.uid == 'FFCcwj3440ZXFcDZVAZzXmGuRQw2';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles — displayName / pfp / role / absence counters.
    // Readable by any signed-in user (needed to show member names & avatars).
    // Writable by signed-in users (leaders update teammates' roles/absences).
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if request.auth.uid == userId || isPlatformAdmin();
    }

    // Team calendars. Read is required for invite-code lookup and for shared
    // calendars. Owners and team leaders write (create/rename/roles/subsections).
    match /calendars/{calId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isPlatformAdmin());
    }

    // Events / meetings / tasks.
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isPlatformAdmin());
    }

    // Bug reports & feedback. Any signed-in user may file one, but only the
    // platform admin can read them, and nobody can edit or delete them from the
    // client (keeps the audit trail intact).
    match /bugReports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read: if isPlatformAdmin();
      allow update: if isPlatformAdmin();
      allow delete: if isPlatformAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
